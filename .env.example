# Скопіюйте в .env і підлаштуйте під свій Docker / хост.
# На Railway: змінну DATABASE_URL зазвичай підставляють з сервісу Postgres (Reference).
# ?schema=public — для Prisma; pg_dump/pg_restore у scripts/one-time-db-transfer самі прибирають його з URI.
DATABASE_URL="postgresql://electroheat:electroheat@localhost:5432/electroheat?schema=public"

# Фото товарів (див. docs/MEDIA-STORAGE.md). Локально за замовчуванням ./storage/media
# MEDIA_ROOT="/absolute/path/to/storage/media"
# Одноразово на Railway pre-deploy: MIRROR_PRODUCT_IMAGES=yes
