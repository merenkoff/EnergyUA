    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "parse:in-heat": "tsx scripts/cli/scrape-in-heat-category.ts",
    "parse:in-heat-catalog": "tsx scripts/cli/crawl-in-heat-catalog.ts",
    "parse:et-file": "tsx scripts/cli/parse-et-market-file.ts",
    "parse:et-category": "tsx scripts/cli/scrape-et-market-category.ts",
    "parse:et-catalog": "tsx scripts/cli/crawl-et-market-catalog.ts",
    "parse:vsesezon-catalog": "tsx scripts/cli/crawl-vsesezon-catalog.ts",
    "import:catalog": "tsx scripts/cli/import-unified-json.ts",
    "import:catalog-trees": "tsx scripts/cli/import-manifest-categories.ts",
    "import:prune-legacy-cats": "tsx scripts/cli/prune-legacy-import-categories.ts",
    "import:prune-empty-cats": "tsx scripts/cli/prune-empty-categories.ts",
